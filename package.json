{
  "name": "wemail",
  "version": "0.1.5",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.18.2",
  "scripts": {
    "dev": "pnpm --parallel --filter @wemail/worker --filter @wemail/web run dev",
    "dev:web": "pnpm --dir apps/web run dev",
    "dev:worker": "pnpm --dir apps/worker run dev",
    "dev:docs": "pnpm --dir apps/docs run dev",
    "lint": "node scripts/run-task.mjs lint",
    "typecheck": "node scripts/run-task.mjs typecheck",
    "test": "node scripts/run-task.mjs test",
    "build": "node scripts/run-task.mjs build",
    "build:docs": "pnpm --dir apps/docs run build",
    "lint:docs": "pnpm --dir apps/docs run lint",
    "typecheck:docs": "pnpm --dir apps/docs run typecheck",
    "api-catalog:generate": "node apps/worker/scripts/generate-api-interface-catalog.mjs",
    "api-catalog:check": "node apps/worker/scripts/generate-api-interface-catalog.mjs --check",
    "version:sync": "node scripts/version.mjs sync",
    "version:check": "node scripts/version.mjs check",
    "db:init:worker": "pnpm --dir apps/worker run db:init:local",
    "db:migrate:worker": "pnpm --dir apps/worker run db:migrate:local",
    "test:worker": "node scripts/run-task.mjs test --filter worker",
    "test:web": "node scripts/run-task.mjs test --filter web",
    "test:docs": "node scripts/run-task.mjs test --filter docs",
    "test:shared": "node scripts/run-task.mjs test --filter shared",
    "test:worker:integration": "pnpm --dir apps/worker exec vitest run tests/integration",
    "test:web:integration": "pnpm --dir apps/web exec vitest run src/test/integration",
    "openapi:generate": "node apps/worker/scripts/generate-openapi.mjs",
    "test:e2e": "pnpm exec playwright test -c apps/web/playwright.config.ts",
    "test:e2e:install": "pnpm exec playwright install chromium"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260625.1",
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.6.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.0.4",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.4.0",
    "jsdom": "^29.1.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.2",
    "vite": "^7.3.6",
    "vitest": "^3.2.6",
    "wrangler": "^4.105.0"
  }
}
